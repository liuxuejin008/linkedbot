# ChannelClient (Rust) 配置文件示例
# 复制为 .env 并填写实际值后，运行：cargo run

# ── ChannelServer 连接配置 ─────────────────────────────────────────────────────

# ChannelServer 公网地址（无末尾斜杠）
CHANNEL_SERVER_URL=https://your-channel-server.workers.dev

# 登录凭据（在 ChannelServer 网站注册）
CHANNEL_EMAIL=user@example.com
CHANNEL_PASSWORD=your-password

# ── 频道过滤 ──────────────────────────────────────────────────────────────────

# 只监听指定频道 ID（逗号分隔），留空则监听账号下全部频道
CHANNEL_IDS=

# ── ChannelReceiver 配置 ───────────────────────────────────────────────────────

# 当频道在 ChannelServer 上未配置转发目标时，使用此地址作为默认 ChannelReceiver
CHANNEL_RECEIVER_URL=http://localhost:9999/webhook

# ── 其他配置 ──────────────────────────────────────────────────────────────────

# 从 ChannelServer 重新同步 ChannelReceiver 地址列表的间隔（秒，默认 60）
CHANNEL_SYNC_INTERVAL=60
